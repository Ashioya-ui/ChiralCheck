# ── Required (primary stack) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# ── Alternative: OpenAI only (no Voyage needed) ───────────────────────────────
# OPENAI_API_KEY=sk-proj-...

# ── Alternative: Gemini (uses google-genai SDK, not google-generativeai) ───────
# GEMINI_API_KEY=AIza...

# ── Override auto-detected providers (optional) ───────────────────────────────
# LLM_PROVIDER=anthropic      # anthropic | openai | gemini
# EMBED_PROVIDER=voyage       # voyage | openai | gemini
